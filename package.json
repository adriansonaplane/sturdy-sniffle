{
  "name": "sturdy-sniffle",
  "version": "1.0.0",
  "description": "A Generator WorkShop",
  "main": "index.js",
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "test": "npm run test:unit && npm run test:integration && npm run test:property:pr && npm run test:regression && npm run test:security",
    "typecheck": "tsc --noEmit",
    "build": "tsc -p tsconfig.json",
    "build:workbench": "node scripts-build-workbench.mjs",
    "check:workbench": "node scripts-check-workbench.mjs",
    "test:unit": "node --experimental-vm-modules node_modules/jest/bin/jest.js --runInBand test/dungeon/unit",
    "test:integration": "node --experimental-vm-modules node_modules/jest/bin/jest.js --runInBand test/dungeon/integration",
    "test:property:pr": "node --experimental-vm-modules node_modules/jest/bin/jest.js --runInBand test/dungeon/property",
    "test:property:nightly": "T1_PROPERTY_SEEDS=10000 node --experimental-vm-modules node_modules/jest/bin/jest.js --runInBand test/dungeon/property",
    "test:property:release": "T1_PROPERTY_SEEDS=100000 node --experimental-vm-modules node_modules/jest/bin/jest.js --runInBand test/dungeon/property",
    "test:regression": "node --experimental-vm-modules node_modules/jest/bin/jest.js --runInBand test/dungeon/regression",
    "test:browser": "playwright test test/browser/workbench.spec.ts test/browser/controls.spec.ts test/browser/overlays.spec.ts test/browser/importExport.spec.ts test/browser/renderer.spec.ts test/browser/lifecycle.spec.ts",
    "test:visual": "playwright test test/browser/visual.spec.ts",
    "test:accessibility": "playwright test test/browser/accessibility.spec.ts",
    "test:performance": "node --experimental-vm-modules node_modules/jest/bin/jest.js --runInBand test/dungeon/performance",
    "test:coverage": "node --experimental-vm-modules node_modules/jest/bin/jest.js --runInBand --coverage test/dungeon/unit test/dungeon/integration test/dungeon/property test/dungeon/regression test/dungeon/security",
    "test:security": "node --experimental-vm-modules node_modules/jest/bin/jest.js --runInBand test/dungeon/security",
    "verify": "npm run typecheck && npm run build && npm run build:workbench && npm run check:workbench && npm test && npm run test:performance && npm run test:coverage && git diff --check",
    "verify:release": "npm run verify && npm run test:property:nightly && npm run test:property:release"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "devDependencies": {
    "@axe-core/playwright": "^4.10.2",
    "@playwright/test": "^1.56.1",
    "@types/jest": "^30.0.0",
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "fast-check": "^4.3.0",
    "http-server": "^14.1.1",
    "jest": "^30.4.2",
    "playwright": "^1.56.1",
    "ts-jest": "^29.4.11",
    "tsx": "^4.23.1",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@types/delaunator": "^5.0.0",
    "@types/three": "^0.180.0",
    "delaunator": "^5.0.1",
    "esbuild": "^0.25.11",
    "three": "^0.180.0"
  }
}
