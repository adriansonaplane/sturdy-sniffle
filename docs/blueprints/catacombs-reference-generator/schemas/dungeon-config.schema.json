{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/schemas/catacombs-reference-generator/dungeon-config.schema.json",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "schemaVersion": {
      "type": "string"
    },
    "generatorVersion": {
      "type": "string"
    },
    "rootSeed": {
      "type": "string",
      "pattern": "^(0|[1-9][0-9]*)$"
    },
    "generationMode": {
      "enum": [
        "procedural",
        "predefined",
        "hybrid"
      ]
    },
    "environmentId": {
      "const": "catacombs"
    },
    "layoutProfileId": {
      "const": "graph.catacombs.layered_braided"
    },
    "gameType": {
      "enum": [
        "speed_run",
        "hunt",
        "endurance"
      ]
    },
    "difficulty": {
      "enum": [
        "normal",
        "hard",
        "expert",
        "nightmare",
        "hell"
      ]
    },
    "authorizedPlayerCount": {
      "type": "integer",
      "minimum": 1,
      "maximum": 8
    },
    "template": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "version"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "version": {
          "type": "string"
        }
      }
    },
    "subBiome": {
      "type": "string"
    },
    "structuralModifiers": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "gameplayModifiers": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "contentTableVersions": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "assetRegistryVersion": {
      "type": "string"
    }
  },
  "required": [
    "schemaVersion",
    "generatorVersion",
    "rootSeed",
    "generationMode",
    "environmentId",
    "layoutProfileId",
    "gameType",
    "difficulty",
    "authorizedPlayerCount",
    "structuralModifiers",
    "gameplayModifiers",
    "contentTableVersions",
    "assetRegistryVersion"
  ]
}
