{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/schemas/catacombs-reference-generator/graph-template.schema.json",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "schemaVersion": {
      "type": "string"
    },
    "templateId": {
      "type": "string"
    },
    "templateVersion": {
      "type": "string"
    },
    "generationMode": {
      "enum": [
        "procedural",
        "predefined",
        "hybrid"
      ]
    },
    "layoutAlgorithm": {
      "const": "catacombs.layered_braided"
    },
    "nodes": {
      "type": "array"
    },
    "edges": {
      "type": "array"
    }
  },
  "required": [
    "schemaVersion",
    "templateId",
    "templateVersion",
    "generationMode",
    "layoutAlgorithm",
    "nodes",
    "edges"
  ]
}
