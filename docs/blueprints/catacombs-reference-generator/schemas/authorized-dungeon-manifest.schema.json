{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/schemas/catacombs-reference-generator/authorized-dungeon-manifest.schema.json",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "schemaVersion": {
      "type": "string"
    },
    "manifestVersion": {
      "type": "string"
    },
    "sessionId": {
      "type": "string"
    },
    "dungeonId": {
      "type": "string"
    },
    "generatorVersion": {
      "type": "string"
    },
    "environmentVersion": {
      "type": "string"
    },
    "contentVersion": {
      "type": "string"
    },
    "canonicalChecksum": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "checksumAlgorithm": {
      "const": "sha256"
    },
    "signature": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "algorithm",
        "keyId",
        "value"
      ],
      "properties": {
        "algorithm": {
          "enum": [
            "Ed25519",
            "ES256",
            "TEST_FAKE_NONPRODUCTION"
          ]
        },
        "keyId": {
          "type": "string"
        },
        "value": {
          "type": "string"
        }
      }
    },
    "expiresAt": {
      "type": "string",
      "format": "date-time"
    },
    "resolvedPayloadUri": {
      "type": "string"
    },
    "resolvedPayloadId": {
      "type": "string"
    }
  },
  "required": [
    "schemaVersion",
    "manifestVersion",
    "sessionId",
    "dungeonId",
    "generatorVersion",
    "environmentVersion",
    "contentVersion",
    "canonicalChecksum",
    "checksumAlgorithm",
    "signature",
    "expiresAt"
  ]
}
